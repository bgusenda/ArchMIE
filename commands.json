[
    {
        "name": "Update System",
        "command": "sudo pacman -Syu"
    },
    {
        "name": "Install Package",
        "command": "sudo pacman -S {package}"
    },
    {
        "name": "Remove Package",
        "command": "sudo pacman -R {package}"
    },
    {
        "name": "List Installed Packages",
        "command": "pacman -Q"
    },
    {
        "name": "Search Package",
        "command": "pacman -Ss {search_term}"
    }
]